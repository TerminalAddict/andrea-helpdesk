# ============================================================
# Andrea Helpdesk - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-helpdesk-domain
APP_TIMEZONE=Pacific/Auckland
APP_DATE_FORMAT=d/m/Y
APP_DATETIME_FORMAT="d/m/Y H:i"

# Ticket Settings
TICKET_PREFIX=HD

# Security
# Must be at least 32 random characters - used for JWT signing and encrypting settings
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ============================================================
# Database
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=helpdesk
DB_USERNAME=helpdesk_user
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ============================================================
# Storage (absolute path, OUTSIDE public_html)
# ============================================================
STORAGE_PATH=/var/www/andrea-helpdesk-storage
MAX_ATTACHMENT_SIZE=10485760

# ============================================================
# SMTP - Outbound Email (TLS)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME="Andrea Helpdesk"
SMTP_REPLY_TO=
SMTP_ENCRYPTION=tls

# ============================================================
# IMAP - Inbound Email Polling
# The IMAP account is monitored for new tickets.
# The SMTP reply-to address may differ from the IMAP address.
# ============================================================
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_ENCRYPTION=ssl
IMAP_DELETE_AFTER_IMPORT=false

# ============================================================
# Slack Notifications
# ============================================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#helpdesk

# ============================================================
# Admin Account (used by: make db-seed)
# ============================================================
ADMIN_NAME="Paul Willard"
ADMIN_EMAIL=paul@netent.co.nz
ADMIN_PASSWORD=
